---
interface Props {
  title: string;
  category: 'smartphone' | 'gaming' | 'ai';
  source: string;
  sourceUrl: string;
  publishedAt: Date;
  slug: string;
  image?: string;
  excerpt?: string;
}

const { title, category, source, sourceUrl, publishedAt, slug, image, excerpt } = Astro.props;

const categoryClasses = {
  smartphone: 'category-smartphone',
  gaming: 'category-gaming',
  ai: 'category-ai',
};

const badgeClass = categoryClasses[category];

// Estimate read time (avg 200 wpm, 3 paragraphs)
const readTime = '4 min read';

const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<a href={`/articles/${slug}`} class="group block">
  <article class="article-card bg-white rounded-xl overflow-hidden border border-slate-200 shadow-sm hover:border-slate-300">
    {/* Thumbnail */}
    {image ? (
      <div class="aspect-[16/9] w-full overflow-hidden bg-slate-100">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[16/9] w-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
        <span class="text-slate-300 text-5xl font-bold opacity-30">
          {title.charAt(0)}
        </span>
      </div>
    )}

    {/* Content */}
    <div class="p-5">
      {/* Meta row */}
      <div class="flex items-center justify-between mb-3">
        <span class={`category-badge ${badgeClass}`}>
          {category}
        </span>
        <span class="text-xs text-slate-400">{readTime}</span>
      </div>

      {/* Title */}
      <h3 class="font-bold text-slate-900 text-base leading-snug mb-2 group-hover:text-sky-600 transition-colors line-clamp-2">
        {title}
      </h3>

      {/* Source & Date */}
      <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-100">
        <span class="text-xs text-slate-500">
          <span class="font-medium">{source}</span>
        </span>
        <time class="text-xs text-slate-400" datetime={new Date(publishedAt).toISOString()}>
          {formattedDate}
        </time>
      </div>
    </div>
  </article>
</a>