---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

// Get approved articles from collection
const approvedArticles = await getCollection('articles');

// Sample articles for demo (these will be replaced by real content later)
const sampleArticles = [
  {
    slug: 'samsung-galaxy-s25-ultra-leaks',
    data: {
      title: 'Samsung Galaxy S25 Ultra Leaks: 200MP Camera and Snapdragon 8 Gen 4',
      category: 'smartphone' as const,
      source: 'Android Authority',
      sourceUrl: 'https://androidauthority.com',
      publishedAt: new Date('2025-06-01'),
    },
  },
  {
    slug: 'playstation-6-development-report',
    data: {
      title: 'PlayStation 6 Development Reportedly Underway with AMD Partnership',
      category: 'gaming' as const,
      source: 'IGN',
      sourceUrl: 'https://ign.com',
      publishedAt: new Date('2025-05-28'),
    },
  },
  {
    slug: 'gpt-5-benchmarks-reasoning',
    data: {
      title: 'GPT-5 Benchmarks Reveal Breakthrough in Reasoning Capabilities',
      category: 'ai' as const,
      source: 'The Verge',
      sourceUrl: 'https://theverge.com',
      publishedAt: new Date('2025-05-30'),
    },
  },
];

// Combine real articles with sample articles
const combinedArticles = [...approvedArticles, ...sampleArticles];

// Sort by date
const sortedArticles = combinedArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Category filter state (for demo, show all)
const categories = ['smartphone', 'gaming', 'ai'] as const;

const categoryColors = {
  smartphone: 'bg-blue-500/20 text-blue-300 border-blue-500/30 hover:bg-blue-500/30',
  gaming: 'bg-purple-500/20 text-purple-300 border-purple-500/30 hover:bg-purple-500/30',
  ai: 'bg-green-500/20 text-green-300 border-green-500/30 hover:bg-green-500/30',
};

const today = new Date().toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title="TechPulse Daily">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-2">Welcome to TechPulse Daily</h1>
      <p class="text-slate-400 text-lg">Your daily tech news, distilled — {today}</p>
    </div>

    <!-- Category Filter Pills -->
    <div class="flex flex-wrap justify-center gap-2 mb-8">
      <button
        class="category-pill px-4 py-2 rounded-full text-sm font-medium border border-slate-600 bg-slate-800 text-slate-300 hover:border-sky-500/50 transition-all"
        data-category="all"
      >
        All
      </button>
      {categories.map((cat) => (
        <button
          class={`category-pill px-4 py-2 rounded-full text-sm font-medium border transition-all ${categoryColors[cat]}`}
          data-category={cat}
        >
          {cat.toUpperCase()}
        </button>
      ))}
    </div>

    {sortedArticles.length === 0 ? (
      <div class="text-center py-16 text-slate-400">
        <p class="text-xl">No articles yet — check back soon!</p>
      </div>
    ) : (
      <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedArticles.map((article) => (
          <div class="article-item" data-category={article.data.category}>
            <ArticleCard
              title={article.data.title}
              category={article.data.category}
              source={article.data.source}
              sourceUrl={article.data.sourceUrl}
              publishedAt={article.data.publishedAt}
              slug={article.slug}
            />
          </div>
        ))}
      </div>
    )}
  </div>

  <script>
    // Simple category filter functionality
    document.addEventListener('DOMContentLoaded', () => {
      const pills = document.querySelectorAll('.category-pill');
      const articles = document.querySelectorAll('.article-item');

      pills.forEach((pill) => {
        pill.addEventListener('click', () => {
          const category = pill.getAttribute('data-category');

          // Update active state
          pills.forEach((p) => {
            p.classList.remove('ring-2', 'ring-sky-500');
          });
          pill.classList.add('ring-2', 'ring-sky-500');

          // Filter articles
          articles.forEach((article) => {
            const articleCategory = article.getAttribute('data-category');
            if (category === 'all' || articleCategory === category) {
              (article as HTMLElement).style.display = 'block';
            } else {
              (article as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    });
  </script>
</BaseLayout>
