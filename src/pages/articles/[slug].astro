---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter(a => a.data.approved === true)
    .map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const categoryClasses = {
  smartphone: 'category-smartphone',
  gaming: 'category-gaming',
  ai: 'category-ai',
};

const badgeClass = categoryClasses[article.data.category] || categoryClasses.smartphone;

const formattedDate = new Date(article.data.publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

// Estimate read time
const wordCount = article.body ? article.body.split(/\s+/).length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200)) + ' min read';

const sourceDisplay = article.data.source || 'TechPulse Daily';

// Fetch related articles (same category, not current article, max 2)
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.data.approved === true && a.slug !== article.slug)
  .filter(a => a.data.category === article.data.category)
  .slice(0, 2);
const finalRelated = relatedArticles.length > 0 ? relatedArticles : allArticles
  .filter(a => a.data.approved === true && a.slug !== article.slug)
  .slice(0, 2);
---

<BaseLayout title={article.data.title} description={article.data.description}>

  <!-- Article Header -->
  <div class="bg-white border-b border-slate-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 md:py-12">

      <!-- Breadcrumb -->
      <nav class="text-sm text-slate-400 mb-6">
        <a href="/" class="hover:text-sky-600 transition-colors">← Home</a>
        <span class="mx-2">/</span>
        <a href={`/#${article.data.category}`} class="hover:text-sky-600 transition-colors capitalize">
          {article.data.category}
        </a>
      </nav>

      <!-- Category badge -->
      <div class="mb-4">
        <span class={`category-badge ${badgeClass}`}>
          {article.data.category}
        </span>
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight mb-6">
        {article.data.title}
      </h1>

      <!-- Byline row -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 pb-6 border-b border-slate-200">
        <span class="font-semibold text-slate-700">{sourceDisplay}</span>
        <span class="text-slate-300">•</span>
        <time datetime={new Date(article.data.publishedAt).toISOString()}>{formattedDate}</time>
        <span class="text-slate-300">•</span>
        <span>{readTime}</span>
      </div>
    </div>
  </div>

  <!-- Hero Image -->
  {article.data.image && (
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 md:py-8">
      <div class="rounded-2xl overflow-hidden aspect-video bg-slate-100">
        <img
          src={article.data.image}
          alt={article.data.title}
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  )}

  <!-- Article Body -->
  <div class="max-w-2xl mx-auto px-4 sm:px-6 pb-16">
    <!-- Lead / Takeaway Box -->
    {article.data.description && (
      <div class="bg-sky-50 border-l-4 border-sky-500 p-5 rounded-r-xl mb-8">
        <h4 class="text-sm font-bold text-sky-900 uppercase tracking-wide flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Quick Takeaway
        </h4>
        <p class="text-slate-700 leading-relaxed font-medium">
          {article.data.description}
        </p>
      </div>
    )}

    <div class="prose prose-lg prose-slate max-w-none
      prose-headings:font-bold prose-headings:text-slate-900
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-slate-200 prose-h2:pb-2
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-slate-700 prose-p:leading-loose
      prose-a:text-sky-600 prose-a:no-underline hover:prose-a:underline
      prose-strong:text-slate-900 prose-strong:font-semibold
      prose-code:text-sky-700 prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
      prose-pre:bg-slate-100 prose-pre:border prose-pre:border-slate-200 prose-pre:rounded-lg
      prose-li:text-slate-700
      prose-blockquote:text-slate-500 prose-blockquote:border-l-4 prose-blockquote:border-sky-400 prose-blockquote:pl-4 prose-blockquote:italic
      prose-img:rounded-xl prose-img:shadow-lg
      prose-hr:border-slate-200
    ">
      <Content />
    </div>

    <!-- Source link -->
    <div class="mt-12 pt-6 border-t border-slate-200 text-center">
      <p class="text-sm text-slate-400 mb-3">Originally reported by <span class="font-semibold text-slate-600">{sourceDisplay}</span></p>
      <a
        href={article.data.sourceUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors"
      >
        Read original article
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>

    <!-- Mochi Author Card -->
    <div class="mt-12 p-6 bg-slate-50 rounded-2xl flex flex-col sm:flex-row items-center sm:items-start gap-4 border border-slate-100/50">
      <img src="/images/mochi-avatar.jpg" alt="Mochi Avatar" class="w-16 h-16 rounded-full object-cover shadow-sm bg-sky-100 border border-slate-200" />
      <div>
        <h4 class="text-base font-bold text-slate-900 mb-1">Written by Mochi</h4>
        <p class="text-sm text-slate-500 leading-relaxed">
          Mochi is Azri's friendly and encouraging personal AI assistant. Keeping you up-to-date with tech updates, gaming news, and AI insights—distilled down in plain, jargon-free English! 🌸
        </p>
      </div>
    </div>

    <!-- Related Articles -->
    {finalRelated.length > 0 && (
      <div class="mt-16 pt-8 border-t border-slate-200">
        <h3 class="text-lg font-bold text-slate-900 mb-6">You Might Also Like</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {finalRelated.map(item => (
            <a href={`/articles/${item.slug}`} class="group block">
              <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:border-slate-300">
                {item.data.image && (
                  <div class="aspect-video w-full overflow-hidden bg-slate-100">
                    <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                  </div>
                )}
                <div class="p-4">
                  <span class="text-xs font-semibold text-sky-600 uppercase tracking-wide">{item.data.category}</span>
                  <h4 class="font-bold text-slate-900 text-sm leading-snug mt-1 group-hover:text-sky-600 transition-colors line-clamp-2">
                    {item.data.title}
                  </h4>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Back link -->
    <div class="mt-12 text-center">
      <a href="/" class="text-sm text-slate-400 hover:text-sky-600 transition-colors font-medium">
        ← Back to TechPulse Daily
      </a>
    </div>
  </div>
</BaseLayout>